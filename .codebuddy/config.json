{
  "instructions": {
    "enabled": true,
    "paths": [
      ".github/instructions/"
    ],
    "defaultStrategy": "merge",
    "autoLoad": true
  },
  "memoryBank": {
    "enabled": true,
    "path": "memory-bank/",
    "autoLoad": true
  },
  "agents": {
    "enabled": true,
    "path": ".github/agents/",
    "autoDiscover": true,
    "filePattern": "*.agent.md"
  }
}
