# Dockerfile.cnb - Derived image for CNB / buildpack workflows
# Inherit from published base image to reuse cached GCC layer

ARG BASE_IMAGE=ghcr.io/ORG/base-gcc:12
FROM ${BASE_IMAGE}

RUN code-server --install-extension cnbcool.cnb-welcome &&\
    code-server --install-extension tencent-cloud.coding-copilot

WORKDIR /workspace
COPY . /workspace
